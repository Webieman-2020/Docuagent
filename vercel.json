{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/process",     "dest": "/api/index.py" },
    { "src": "/health",      "dest": "/api/index.py" },
    { "src": "/(.*)",        "dest": "/api/index.py" }
  ]
}
